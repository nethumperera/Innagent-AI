# ════════════════════════════════════════════════════════════════
# InnAgent AI — Environment Variables
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════════════════════

# Groq API (free — LLaMA-3.3-70B)
GROQ_API_KEY=your_groq_api_key_here

# Supabase (free Spark tier)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Twilio WhatsApp (free sandbox)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# App config
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO

# API Key for GitHub Actions cron jobs
INNAGENT_API_KEY=your_secure_api_key_here

# GitHub Actions secrets (same keys used in workflows)
# Set these in GitHub repo Settings > Secrets > Actions:
# - GROQ_API_KEY
# - SUPABASE_URL
# - SUPABASE_SERVICE_ROLE_KEY
# - INNAGENT_API_KEY
# - INNAGENT_API_URL (your deployed backend URL)
